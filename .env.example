# STRIPE_SECRET_KEY: Required for Wallet app payments
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# SPOTIFY_CLIENT_ID: Required for Spotify player
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# CALENDLY_API_KEY: Required for Calendar integration
CALENDLY_API_KEY=""
